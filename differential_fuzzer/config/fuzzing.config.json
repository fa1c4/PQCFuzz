{
  "template_by_primitive": {
    "kem": "differential_fuzzer/templates/kem_pair_fuzzer.cpp",
    "sig": "differential_fuzzer/templates/sig_pair_fuzzer.cpp",
    "kpke": "differential_fuzzer/templates/kpke_pair_fuzzer.cpp"
  },
  "default_oracle_mode": {
    "kem": "kem_cross_impl_shared_semantics",
    "sig": "sig_cross_impl_verify_semantics",
    "kpke": "kpke_cross_impl_encrypt_semantics"
  },
  "default_determinism_policy": {
    "prefer_seeded_keygen": true,
    "prefer_seeded_encaps": true,
    "prefer_seeded_sign": false,
    "compare_raw_signature_bytes": false
  },
  "enabled_subtests": {
    "kem": [
      "left_seeded_keygen_local_roundtrip",
      "right_seeded_keygen_local_roundtrip",
      "left_keypair_cross_impl_encaps_if_allowed",
      "right_keypair_cross_impl_encaps_if_allowed",
      "cross_decaps_if_declared_compatible",
      "corrupt_ciphertext_negative"
    ],
    "sig": [
      "left_sign_left_verify",
      "left_sign_right_verify_if_allowed",
      "right_sign_right_verify",
      "right_sign_left_verify_if_allowed",
      "mutated_signature_negative",
      "mutated_message_negative",
      "mutated_public_key_negative"
    ],
    "kpke": [
      "kpke_keygen_consistency",
      "kpke_encrypt_compare",
      "kpke_decrypt_roundtrip",
      "kpke_corrupt_ciphertext_consistency"
    ]
  },
  "mismatch_labels": {
    "kem": [
      "return_code_mismatch",
      "shared_secret_mismatch",
      "abi_length_mismatch",
      "interop_policy_violation",
      "sanitizer_crash"
    ],
    "sig": [
      "return_code_mismatch",
      "verify_result_mismatch",
      "cross_verify_failure",
      "unexpected_acceptance",
      "unexpected_rejection",
      "interop_policy_violation",
      "sanitizer_crash"
    ],
    "kpke": [
      "return_code_mismatch",
      "keygen_mismatch",
      "ciphertext_mismatch",
      "decrypt_mismatch",
      "mutated_decrypt_mismatch",
      "interop_policy_violation",
      "sanitizer_crash"
    ]
  },
  "replay_policy": {
    "write_findings": true,
    "finding_format": "jsonl",
    "summary_filename": "summary.json"
  },
  "crash_artifact_policy": {
    "preserve_reproducer": true,
    "preserve_run_log": true,
    "write_minimal_side_artifact": false
  },
  "sanitizer_build_flags": [
    "-fsanitize=address,undefined",
    "-fno-omit-frame-pointer"
  ],
  "resource_defaults": {
    "timeout_seconds": 30,
    "rss_mb": 2048
  }
}
