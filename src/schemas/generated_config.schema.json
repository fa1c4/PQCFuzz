{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pqcfuzz.local/schemas/generated_config.schema.json",
  "type": "object",
  "required": [
    "version",
    "job_id",
    "pair_id",
    "oracle_suite",
    "relation_mode",
    "algorithm",
    "primitive_type",
    "algorithm_metadata",
    "oracles",
    "paths"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "job_id": {
      "type": "string"
    },
    "pair_id": {
      "type": "string"
    },
    "oracle_suite": {
      "enum": [
        "fips",
        "metamorphic"
      ]
    },
    "relation_mode": {
      "enum": [
        "single-target",
        "self-reference",
        "cross-implementation",
        "single-liboqs",
        "liboqs-vs-pqclean"
      ]
    },
    "algorithm": {
      "type": "string"
    },
    "primitive_type": {
      "enum": [
        "kem",
        "sig"
      ]
    },
    "algorithm_metadata": {
      "type": "object"
    },
    "pair": {
      "type": "object"
    },
    "target": {
      "type": "object"
    },
    "target_runtime": {
      "type": "string"
    },
    "liboqs_version": {
      "type": "string"
    },
    "oracles": {
      "type": "array"
    },
    "paths": {
      "type": "object"
    }
  }
}
