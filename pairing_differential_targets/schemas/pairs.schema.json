{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pq-cdf.local/pairing_differential_targets/pairs.schema.json",
  "title": "PQ-CDF Pairs",
  "type": "array",
  "items": {
    "$ref": "#/$defs/pair"
  },
  "$defs": {
    "operation_ref": {
      "type": "object",
      "required": [
        "source_file",
        "function"
      ],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "build": {
      "type": "object",
      "required": [
        "build_mode",
        "implementation_dir",
        "declaration_file",
        "implementation_files",
        "include_dirs",
        "common_deps",
        "defines"
      ],
      "properties": {
        "build_mode": {
          "enum": [
            "library",
            "source"
          ]
        },
        "library_name": {
          "type": "string",
          "minLength": 1
        },
        "implementation_dir": {
          "type": "string",
          "minLength": 1
        },
        "declaration_file": {
          "type": "string",
          "minLength": 1
        },
        "implementation_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "include_dirs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_deps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "defines": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "abi": {
      "type": "object",
      "required": [
        "pk_len",
        "sk_len",
        "ct_len",
        "ss_len",
        "sig_max_len",
        "msg_len"
      ],
      "properties": {
        "pk_len": {
          "type": "integer",
          "minimum": 1
        },
        "sk_len": {
          "type": "integer",
          "minimum": 1
        },
        "ct_len": {
          "type": [
            "integer",
            "null"
          ]
        },
        "ss_len": {
          "type": [
            "integer",
            "null"
          ]
        },
        "sig_max_len": {
          "type": [
            "integer",
            "null"
          ]
        },
        "msg_len": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "required": [
        "supports_keygen_derand",
        "supports_encaps_derand",
        "supports_sign_derand",
        "wire_format_class",
        "interop_class"
      ],
      "properties": {
        "supports_keygen_derand": {
          "type": "boolean"
        },
        "supports_encaps_derand": {
          "type": "boolean"
        },
        "supports_sign_derand": {
          "type": "boolean"
        },
        "wire_format_class": {
          "type": "string",
          "minLength": 1
        },
        "interop_class": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "bundle": {
      "type": "object",
      "required": [
        "project_id",
        "project_name",
        "implementation_id",
        "api_variant",
        "backend_variant",
        "build",
        "abi",
        "capabilities",
        "operations"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "project_name": {
          "type": "string",
          "minLength": 1
        },
        "implementation_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "api_variant": {
          "type": "string",
          "minLength": 1
        },
        "backend_variant": {
          "type": "string",
          "minLength": 1
        },
        "build": {
          "$ref": "#/$defs/build"
        },
        "abi": {
          "$ref": "#/$defs/abi"
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "operations": {
          "type": "object",
          "properties": {
            "keygen": {
              "$ref": "#/$defs/operation_ref"
            },
            "encaps": {
              "$ref": "#/$defs/operation_ref"
            },
            "decaps": {
              "$ref": "#/$defs/operation_ref"
            },
            "kpke_keygen": {
              "$ref": "#/$defs/operation_ref"
            },
            "kpke_encrypt": {
              "$ref": "#/$defs/operation_ref"
            },
            "kpke_decrypt": {
              "$ref": "#/$defs/operation_ref"
            },
            "sign": {
              "$ref": "#/$defs/operation_ref"
            },
            "verify": {
              "$ref": "#/$defs/operation_ref"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "pair": {
      "type": "object",
      "required": [
        "pair_id",
        "family",
        "family_slug",
        "parameter_set",
        "primitive_type",
        "left",
        "right",
        "interop_policy",
        "provenance_relation",
        "status"
      ],
      "properties": {
        "pair_id": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "family_slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+$"
        },
        "parameter_set": {
          "type": "string",
          "minLength": 1
        },
        "primitive_type": {
          "enum": [
            "kem",
            "sig",
            "kpke"
          ]
        },
        "left": {
          "$ref": "#/$defs/bundle"
        },
        "right": {
          "$ref": "#/$defs/bundle"
        },
        "interop_policy": {
          "type": "object"
        },
        "provenance_relation": {
          "enum": [
            "unknown",
            "shared-upstream-likely",
            "distinct-likely"
          ]
        },
        "status": {
          "enum": [
            "enabled",
            "manual-review"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "primitive_type": {
                "const": "kem"
              }
            }
          },
          "then": {
            "properties": {
              "left": {
                "properties": {
                  "operations": {
                    "required": [
                      "keygen",
                      "encaps",
                      "decaps"
                    ]
                  }
                }
              },
              "right": {
                "properties": {
                  "operations": {
                    "required": [
                      "keygen",
                      "encaps",
                      "decaps"
                    ]
                  }
                }
              },
              "interop_policy": {
                "type": "object",
                "required": [
                  "public_key_exchange",
                  "ciphertext_exchange"
                ],
                "properties": {
                  "public_key_exchange": {
                    "enum": [
                      "declared-compatible",
                      "same-project-only",
                      "no-cross-exchange",
                      "manual-review"
                    ]
                  },
                  "ciphertext_exchange": {
                    "enum": [
                      "declared-compatible",
                      "same-project-only",
                      "no-cross-exchange",
                      "manual-review"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "primitive_type": {
                "const": "sig"
              }
            }
          },
          "then": {
            "properties": {
              "left": {
                "properties": {
                  "operations": {
                    "required": [
                      "keygen",
                      "sign",
                      "verify"
                    ]
                  }
                }
              },
              "right": {
                "properties": {
                  "operations": {
                    "required": [
                      "keygen",
                      "sign",
                      "verify"
                    ]
                  }
                }
              },
              "interop_policy": {
                "type": "object",
                "required": [
                  "public_key_exchange",
                  "signature_exchange"
                ],
                "properties": {
                  "public_key_exchange": {
                    "enum": [
                      "declared-compatible",
                      "same-project-only",
                      "no-cross-exchange",
                      "manual-review"
                    ]
                  },
                  "signature_exchange": {
                    "enum": [
                      "declared-compatible",
                      "same-project-only",
                      "no-cross-exchange",
                      "manual-review"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
